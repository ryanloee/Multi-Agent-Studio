{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stream Events",
  "description": "Event types for real-time streaming between Orchestrator and Frontend",
  "definitions": {
    "StreamEvent": {
      "type": "object",
      "required": ["type", "node_id", "run_id", "timestamp"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["llm_token", "tool_call", "tool_result", "shell_stdout", "status", "error"]
        },
        "node_id": { "type": "string" },
        "run_id": { "type": "string" },
        "content": { "type": "string" },
        "tool_name": { "type": "string" },
        "metadata": { "type": "object" },
        "timestamp": { "type": "number" }
      }
    }
  }
}
