{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Node Configuration",
  "description": "Configuration injected into OpenCode for each workflow node",
  "type": "object",
  "required": ["model", "agents"],
  "properties": {
    "model": {
      "type": "object",
      "required": ["provider", "id"],
      "properties": {
        "provider": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tools": {
            "type": "array",
            "items": { "type": "string" }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["allow", "deny", "ask"]
            }
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "properties": {
        "servers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string" },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
